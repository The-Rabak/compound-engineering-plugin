{
  "name": "@every-env/compound-plugin",
  "version": "0.7.0",
  "type": "module",
  "private": false,
  "bin": {
    "compound-plugin": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build:platforms": "bun run src/index.ts build portable/compound-engineering --output .",
    "build:copilot": "bun run src/index.ts build portable/compound-engineering --output . --targets copilot",
    "build:codex": "bun run src/index.ts build portable/compound-engineering --output . --targets codex",
    "seed:codex-models": "bun run src/scripts/seed-codex-models.ts",
    "verify:generated": "bun run src/scripts/verify-generated.ts",
    "convert": "bun run src/index.ts convert",
    "list": "bun run src/index.ts list",
    "cli:install": "bun run src/index.ts install",
    "sync:ov": "bun run src/index.ts sync-ov portable/compound-engineering",
    "test": "bun test"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "bun-types": "^1.0.0"
  }
}
